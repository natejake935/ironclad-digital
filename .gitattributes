# Normalize all text files to LF on the server regardless of OS.
# Prevents .gitignore patterns from silently failing on Linux hosts
# when files were committed from Windows with CRLF endings.
* text=auto eol=lf

# Explicitly force LF for files that must never have CRLF.
.gitignore    text eol=lf
.cpanel.yml   text eol=lf
*.js          text eol=lf
*.json        text eol=lf
*.html        text eol=lf
*.css         text eol=lf
*.md          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.env*        text eol=lf

# Binaries — no line ending conversion.
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.woff        binary
*.woff2       binary
